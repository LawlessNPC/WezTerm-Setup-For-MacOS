# ~/.config/newsboat/config

# --- General behavior ---------------------------------------------------
auto-reload          yes
reload-time          30          # minutes between background refreshes
reload-threads       1           # avoid Newsboat 2.43.0 SQLite cache crashes on macOS
download-retries     2
download-timeout     30
confirm-exit         no
cleanup-on-quit      yes
keep-articles-days   30
text-width           100
prepopulate-query-feeds yes
browser              "open %u"   # macOS: open in default browser

# --- Display formats ----------------------------------------------------
datetime-format      "%Y-%m-%d %H:%M"
feedlist-format      "%4i %n %11u %t"
articlelist-format   "%4i %f %D   %?T?|%-14T|  ?%t"
show-read-feeds      yes
show-read-articles   yes

# --- Vim-style keybindings ---------------------------------------------
bind-key j    down
bind-key k    up
bind-key J    next-feed       articlelist
bind-key K    prev-feed       articlelist
bind-key g    home
bind-key G    end
bind-key l    open
bind-key h    quit
bind-key ^D   pagedown
bind-key ^U   pageup
bind-key R    reload-all
bind-key /    open-search

# --- Cyberpunk-neon theme (maps to your WezTerm/tmux ANSI palette) ------
color background          default   default
color listnormal          cyan      default
color listnormal_unread   white     default   bold
color listfocus           black     magenta
color listfocus_unread    black     magenta   bold
color info                magenta   default   bold
color article             cyan      default
color end-of-text-marker  yellow    default

# Highlight quoted text / links inside articles
highlight article "^(Feed|Title|Author|Link|Date):.*$" yellow  default bold
highlight article "https?://[^ ]+"                      magenta default underline
highlight article "\\[[0-9]+\\]"                         cyan    default bold
